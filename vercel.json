{
    "rewrites": [
      {
        "source": "/",
        "destination": "/index.html"
      },
      {
        "source": "/result/:slug",
        "destination": "/assets/html/:slug.html"
      }
    ],
    "redirects": [
      {
        "source": "/assets/html/:slug.html",
        "destination": "/result/:slug",
        "permanent": true
      }
    ]
  }
  