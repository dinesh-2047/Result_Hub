{
    "rewrites": [
      {
        "source": "/",
        "destination": "/index.html"
      },
      {
        "source": "/result/:slug",
        "destination": "/assets/html/:slug.html"
      }
    ],
    "redirects": [
      {
        "source": "/index.html",
        "destination": "/",
        "permanent": true
      },
      {
        "source": "/assets/html/:slug.html",
        "destination": "/result/:slug",
        "permanent": true
      }
    ],
    "headers": [
      {
        "source": "/assets/csvs/:path*",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
        ]
      }
    ],
    "routes": [
      {
        "src": "/assets/csvs/(.*)",
        "status": 403
      }
    ]
  }
  